{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["index.html", "api/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/health",   "dest": "/server.js" },
    { "src": "/(.*)",     "dest": "/server.js" }
  ]
}
